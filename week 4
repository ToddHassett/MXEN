# task 1

int main(void)
{
    // Set pin 9 as OUTPUT
    DDRH |= (1 << PH6);

    serial0_init();
    char serialString[60] = {};

    while(1) // main loop
    {
        // Lamp ON
        PORTH |= (1 << PH6);
        sprintf(serialString, "\nLamp ON");
        serial0_print_string(serialString);
        milliseconds_delay(500);

        // Lamp OFF
        PORTH &= ~(1 << PH6);
        sprintf(serialString, "\nLamp OFF");
        serial0_print_string(serialString);
        milliseconds_delay(500);
    }

    return(1);
}

